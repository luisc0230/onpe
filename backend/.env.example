# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database (Neon PostgreSQL). Obtener en https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ONPE upstream
ONPE_BASE=https://resultadoelectoral.onpe.gob.pe/presentacion-backend
ONPE_ID_ELECCION=10
ONPE_TIPO_FILTRO=eleccion

# Polling cron (every 7 minutes by default)
POLL_CRON=*/7 * * * *
POLL_ON_BOOT=true

# SMTP (Nodemailer). Zoho Mail por defecto.
# Puertos válidos: 465 (SSL, SMTP_SECURE=true) o 587 (STARTTLS, SMTP_SECURE=false).
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=gerencia@ldxsoftware.com.pe
SMTP_APP_PASSWORD=your_zoho_app_password
MAIL_FROM_NAME=LDX Software - ONPE 2026 Monitor

# BCC chunk size
MAIL_BCC_CHUNK=99

# If true, emails are logged but not sent (useful in dev)
MAIL_DRY_RUN=true
